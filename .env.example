PORT=8001
DB_PATH=./adventure.db
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
# The LLM model to use specifically for the /kids section.
# If unset or if the kids provider base/key are missing, kids requests fall back
# to the default OPENAI_* provider.
KIDS_LLM_API_BASE=
KIDS_LLM_API_KEY=
KIDS_LLM_MODEL=gpt-4o-mini
IMAGEROUTER_API_BASE=https://api.imagerouter.io/v1/openai
IMAGEROUTER_API_KEY=your_imagerouter_api_key_here
IMAGEROUTER_MODEL=imagerouter/auto-image
LLM_TIMEOUT_SEC=60
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.85
LLM_TOP_P=0.95
REQUEST_MAX_BYTES=1048576
FEATURE_FLAGS=novel_gen_v2_prompt_fix,kids_mode,kids_storybook_v2
